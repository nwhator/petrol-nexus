---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Contact | Petrol Nexus" path="/contact">
  <section class="section">
    <h1>Contact</h1>
    <p>Reach our global teams for partnerships, operations support, and media inquiries.</p>
    <div class="grid">
      <article class="card"><h3>Headquarters</h3><p>Houston, TX, USA</p><p><a href="mailto:hq@petrolnexus.com">hq@petrolnexus.com</a></p></article>
      <article class="card"><h3>Commercial Team</h3><p><a href="mailto:sales@petrolnexus.com">sales@petrolnexus.com</a></p><p><a href="tel:+18005550199">+1 (800) 555‑0199</a></p></article>
      <article class="card"><h3>Media Desk</h3><p><a href="mailto:media@petrolnexus.com">media@petrolnexus.com</a></p></article>
    </div>
  </section>

  <section class="section" id="global-offices">
    <h2>Global Offices</h2>
    <div class="grid">
      <article class="card"><h3>EMEA</h3><p>London, UK</p></article>
      <article class="card"><h3>APAC</h3><p>Singapore</p></article>
      <article class="card"><h3>Americas</h3><p>Calgary, Canada</p></article>
    </div>
  </section>
</MainLayout>
