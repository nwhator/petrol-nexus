---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Projects | Petrol Nexus" path="/projects">
  <section class="section" id="global-offices">
    <h1>Projects</h1>
    <p>Selected programs across offshore, refinery, logistics, and energy transition initiatives.</p>
    <div class="grid">
      <article class="card"><h3>North Sea Upgrade</h3><p>Platform modernization with reduced maintenance windows.</p></article>
      <article class="card"><h3>Gulf Coast Reliability</h3><p>Refinery debottlenecking that increased throughput and uptime.</p></article>
      <article class="card"><h3>APAC Terminal Network</h3><p>Cross-border storage and dispatch optimization rollout.</p></article>
    </div>
  </section>
</MainLayout>
